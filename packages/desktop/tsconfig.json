{
  "compilerOptions": {
    "target": "es6",
    "module": "esnext",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "rootDir": "../..",
    "paths": {
      "@interfacez/editor-markdown": ["../editor-markdown/src/index.ts"],
      "@interfacez/ui": ["../ui/src/index.ts"]
    },
    "outDir": "dist",
    "moduleResolution": "bundler",
    "resolveJsonModule": true
  },
  "include": ["src", "vite-env.d.ts"]
}
