{
  "name": "interfacez",
  "productName": "interfacez",
  "version": "1.0.0",
  "description": "interfacez desktop application.",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "test:e2e": "wdio run ./wdio.conf.cjs"
  },
  "keywords": [
    "interfacez",
    "extension-system",
    "plugin-system",
    "modular",
    "composable",
    "interactive",
    "typescript",
    "framework-agnostic"
  ],
  "author": {
    "name": "jerlendds",
    "url": "https://github.com/jerlendds/interfacez"
  },
  "repository": {
    "url": "https://github.com/jerlendds/interfacez"
  },
  "type": "commonjs",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@testing-library/webdriverio": "^3.2.1",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/jasmine": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@wdio/cli": "^9.27.2",
    "@wdio/globals": "^9.27.2",
    "@wdio/jasmine-framework": "^9.27.2",
    "@wdio/local-runner": "^9.27.2",
    "@wdio/spec-reporter": "^9.27.2",
    "electron": "42.3.0",
    "electron-forge-maker-appimage": "github:jerlendds/electron-forge-maker-appimage",
    "typescript": "~6.0.3",
    "vite": "^8.0.14",
    "wdio-electron-service": "^9.2.1",
    "wdio-wait-for": "^3.1.1"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@tursodatabase/database": "^0.6.1",
    "isomorphic-git": "^1.38.3",
    "@lmstudio/sdk": "^1.5.0",
    "@interfacez/editor-markdown": "^1.0.0",
    "@interfacez/ui": "^1.0.0",
    "dompurify": "^3.4.8",
    "electron-squirrel-startup": "^1.0.1",
    "esbuild-wasm": "^0.28.0",
    "monaco-editor": "^0.55.1"
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "es6": true,
      "node": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/eslint-recommended",
      "plugin:@typescript-eslint/recommended",
      "plugin:import/recommended",
      "plugin:import/electron",
      "plugin:import/typescript"
    ],
    "parser": "@typescript-eslint/parser",
    "rules": {
      "import/no-named-as-default": 0
    }
  }
}
